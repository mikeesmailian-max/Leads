# PostgreSQL connection string (Manus AI DB, Supabase, RDS, local Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/megafleet?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Local file storage for uploaded documents (absolute or relative path)
UPLOADS_DIR="./uploads"

# --- OCR: scanned/photographed rate confirmations (optional) ---
# Leave OCR_PROVIDER unset to use the free heuristic parser only (born-digital
# PDFs). Set it to enable AWS Textract for images and scanned PDFs.
# OCR_PROVIDER="aws-textract"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# --- Email inbox ingestion (optional) — auto-pull rate cons + replies ---
# Works with a Gmail "app password" (recommended) or any IMAP/SMTP provider,
# including Office 365. Same credentials are used for both IMAP_* (reading)
# and SMTP_* (sending) below.
# IMAP_HOST="imap.gmail.com"
# IMAP_PORT="993"
# IMAP_MAILBOX="INBOX"
# EMAIL_USER="you@megafleetcorp.com"
# EMAIL_PASSWORD="your-app-password"

# --- Outreach sending (optional) — one-click send instead of copy/paste ---
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# EMAIL_FROM_NAME="Mike @ Mega Fleet Corp"
# EMAIL_FROM_ADDRESS="you@megafleetcorp.com"
# (EMAIL_USER / EMAIL_PASSWORD above are reused for SMTP auth)

# --- Contact enrichment (optional) — find + flag the decision-maker ---
# Get a key at https://developer.apollo.io/
# APOLLO_API_KEY=""

# --- Proactive alerts (optional) — daily digest of what needs attention ---
# Slack: create an Incoming Webhook at https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=""
# SMS via Twilio: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER="+15551234567"
# ALERT_PHONE_NUMBER="+15557654321"

# --- Reply sentiment upgrade (optional) — LLM classification fallback ---
# Only used when the fast heuristic can't categorize a reply. Get a key at
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=""

# --- Cron protection (required if using the /api/cron/* routes) ---
# Any random string; your scheduler sends it as: Authorization: Bearer <value>
# CRON_SECRET="replace-with-openssl-rand-hex-32"
# Cron schedule suggestions once CRON_SECRET is set:
#   /api/cron/icp-sourcing    — daily, pulls new ICP-matching accounts via Apollo
#   /api/cron/hiring-signals  — daily, checks job postings for existing accounts
#   /api/cron/stale-deals     — daily, escalates accounts with no activity in 7+ days
